---
const currentPage = Astro.url.pathname;
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props{
	hideAll?: boolean,
	hideFooter?: boolean,
	hideHeader?: boolean,
}

const { hideAll = false, hideFooter = false, hideHeader = false } = Astro.props
const shouldHideHeader = hideAll || hideHeader
const shouldHideFooter = hideAll || hideFooter
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Caio Abrahão | {currentPage}</title>
		<link rel="stylesheet" href="https://use.typekit.net/pqo7ipr.css">
	</head>
	<!-- Apply themes in the body class -->
	<body class="">
		{!shouldHideHeader && <Header/>}
		<slot />
		{!shouldHideFooter && <Footer/>}
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
